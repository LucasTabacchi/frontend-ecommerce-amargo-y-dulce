# Public URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Server URLs
SITE_URL=http://localhost:3000
STRAPI_URL=http://localhost:1337
STRAPI_GRAPHQL_ENDPOINT=/graphql

# Strapi tokens
# Use STRAPI_API_TOKEN or STRAPI_TOKEN according to your setup.
STRAPI_API_TOKEN=your_strapi_api_token
STRAPI_TOKEN=your_strapi_token

# Mercado Pago
MP_ACCESS_TOKEN=your_mercado_pago_access_token

# Brevo transactional email
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=Amargo y Dulce <no-reply@yourdomain.com>
EMAIL_FROM_NAME=Amargo y Dulce

# Optional: force all transactional emails to this inbox in dev/test
TEST_EMAIL_TO=your_verified_test_email@example.com
